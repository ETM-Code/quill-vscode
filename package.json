{
  "name": "quill-vscode",
  "displayName": "Quill Markdown Editor",
  "description": "Notion-style WYSIWYG markdown editor for VSCode. Open any .md file as a real document: headings, tables, task lists, LaTeX math, and syntax-highlighted code blocks.",
  "version": "0.1.0",
  "publisher": "etm-code",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ETM-Code/quill-vscode"
  },
  "bugs": {
    "url": "https://github.com/ETM-Code/quill-vscode/issues"
  },
  "homepage": "https://github.com/ETM-Code/quill-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "preview",
    "notion",
    "latex",
    "katex",
    "tables",
    "math"
  ],
  "galleryBanner": {
    "color": "#2a1f5e",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "quill.markdownEditor",
        "displayName": "Quill (WYSIWYG)",
        "selector": [
          { "filenamePattern": "*.md" },
          { "filenamePattern": "*.markdown" }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Quill",
      "properties": {
        "quill.rememberLastEditorChoice": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Make whichever editor you last used for a Markdown file the default for opening `.md` and `.markdown` files. Opening a file with Quill makes Quill the default; opening one in the normal text editor makes the text editor the default again. Quill does this by keeping the built-in `#workbench.editorAssociations#` setting in sync with your last choice (it only touches the `*.md` and `*.markdown` entries). Turn this off to leave your editor associations alone."
        }
      }
    },
    "commands": [
      {
        "command": "quill.openWithQuill",
        "title": "Open with Quill (WYSIWYG)",
        "category": "Quill",
        "icon": "$(book)"
      },
      {
        "command": "quill.openWithTextEditor",
        "title": "Open as Text (View Source)",
        "category": "Quill",
        "icon": "$(code)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "quill.openWithQuill",
          "group": "navigation",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && activeCustomEditorId != quill.markdownEditor && !notebookEditorFocused"
        },
        {
          "command": "quill.openWithTextEditor",
          "group": "navigation",
          "when": "activeCustomEditorId == quill.markdownEditor"
        }
      ]
    }
  },
  "scripts": {
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=out/extension.js",
    "build:webview": "esbuild webview-src/index.ts --bundle --format=iife --target=es2020 --outfile=media/webview.js --loader:.ttf=file --loader:.woff=file --loader:.woff2=file",
    "copy:assets": "bun run scripts/copy-assets.ts",
    "build": "bun run build:ext && bun run build:webview && bun run copy:assets",
    "watch:ext": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=out/extension.js --sourcemap --watch",
    "watch:webview": "esbuild webview-src/index.ts --bundle --format=iife --target=es2020 --outfile=media/webview.js --loader:.ttf=file --loader:.woff=file --loader:.woff2=file --sourcemap --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "pretest": "bun run build && tsc -p tsconfig.test.json",
    "test": "node ./out-test/test/runTest.js",
    "package": "bunx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@tiptap/core": "3.17.1",
    "@tiptap/extension-code-block-lowlight": "3.17.1",
    "@tiptap/extension-image": "3.17.1",
    "@tiptap/extension-mathematics": "3.17.1",
    "@tiptap/extension-list": "3.17.1",
    "@tiptap/extension-table": "3.26.0",
    "@tiptap/extension-typography": "3.17.1",
    "@tiptap/extensions": "3.17.1",
    "@tiptap/markdown": "3.17.1",
    "@tiptap/pm": "3.17.1",
    "@tiptap/starter-kit": "3.17.1",
    "highlight.js": "11.11.1",
    "katex": "0.16.28",
    "lowlight": "3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "mocha": "^10.7.3",
    "@types/mocha": "^10.0.7",
    "typescript": "^5.6.2"
  }
}
